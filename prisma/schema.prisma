generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  fullName          String    @map("full_name")
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  provider          String    @default("local")
  providerId        String?   @map("provider_id")
  avatarUrl         String?   @map("avatar_url") @db.LongText
  birthDate         DateTime  @map("birth_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  roles             UserRole[]
  accounts          Account[]
  sessions          Session[]
  schoolMemberships SchoolUser[]
  schoolClassTeachers SchoolClassTeacher[]
  schoolEnrollments SchoolEnrollment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
}

enum InstitutionRole {
  DIRECTOR
  ADMIN
  COORDINATOR
  TEACHER
  STUDENT
}

model School {
  id        String       @id @default(cuid())
  name      String
  email     String
  phone     String?
  status    SchoolStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")

  members SchoolUser[]
  courses SchoolCourse[]

  @@map("schools")
}

model SchoolUser {
  id              String          @id @default(cuid())
  schoolId        String          @map("school_id")
  userId          String          @map("user_id")
  institutionRole InstitutionRole @map("institution_role")
  joinedAt        DateTime        @default(now()) @map("joined_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId])
  @@index([schoolId])
  @@map("school_users")
}

model SchoolCourse {
  id                 String   @id @default(cuid())
  schoolId           String   @map("school_id")
  platformCourseSlug String?  @map("platform_course_slug")
  title              String
  description        String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")

  school  School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes SchoolClass[]

  @@index([schoolId])
  @@map("school_courses")
}

model SchoolClass {
  id             String   @id @default(cuid())
  schoolCourseId String   @map("school_course_id")
  name           String
  semester       String?
  createdAt      DateTime @default(now()) @map("created_at")

  schoolCourse SchoolCourse         @relation(fields: [schoolCourseId], references: [id], onDelete: Cascade)
  enrollments  SchoolEnrollment[]
  teachers     SchoolClassTeacher[]

  @@index([schoolCourseId])
  @@map("school_classes")
}

model SchoolClassTeacher {
  id      String @id @default(cuid())
  classId String @map("class_id")
  userId  String @map("user_id")

  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@map("school_class_teachers")
}

model SchoolEnrollment {
  id         String   @id @default(cuid())
  classId    String   @map("class_id")
  userId     String   @map("user_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([userId])
  @@map("school_enrollments")
}
